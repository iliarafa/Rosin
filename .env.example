# Multi-LLM Verification System - Environment Variables
# Copy this file to .env and fill in your API keys

# OpenAI API (required for GPT models)
AI_INTEGRATIONS_OPENAI_API_KEY=your_openai_api_key_here
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic API (required for Claude models)
AI_INTEGRATIONS_ANTHROPIC_API_KEY=your_anthropic_api_key_here
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com

# Google Gemini API (required for Gemini models)
AI_INTEGRATIONS_GEMINI_API_KEY=your_gemini_api_key_here

# xAI/Grok API (required for Grok models)
XAI_API_KEY=your_xai_api_key_here

# Exa.ai Search API (preferred — neural search for Live Research)
# Free tier (1000 searches/month): https://exa.ai — sign up and copy your API key
EXA_API_KEY=your_exa_api_key_here

# Tavily Search API (fallback if Exa is not configured)
# Free tier: https://tavily.com — sign up and copy your API key
TAVILY_API_KEY=your_tavily_api_key_here

# Database (PostgreSQL)
DATABASE_URL=your_postgresql_connection_string_here

# Session Secret (for secure cookies)
SESSION_SECRET=your_session_secret_here

# Sign in with Apple (web — separate from iOS native)
VITE_APPLE_SERVICES_ID=
VITE_APPLE_RETURN_URL=http://localhost:5000/sign-in
